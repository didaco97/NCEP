APP_NAME=NCEP Backend
APP_ENV=local
API_V1_PREFIX=/api/v1

# Copy this file to .env and replace placeholder values before running locally.
DATABASE_URL=postgresql+psycopg://ncep_dev:<local-dev-password>@127.0.0.1:5432/ncep_dev?connect_timeout=5
POSTGRES_DB=ncep_dev
POSTGRES_USER=ncep_dev
POSTGRES_PASSWORD=<local-dev-password>
POSTGRES_PORT=5432
